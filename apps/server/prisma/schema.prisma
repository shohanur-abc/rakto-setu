generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  RECIPIENT @map("recipient")
  DONOR     @map("donor")
  ADMIN     @map("admin")

  @@map("role")
}

enum BloodGroup {
  A_POSITIVE  @map("A+")
  A_NEGATIVE  @map("A-")
  B_POSITIVE  @map("B+")
  B_NEGATIVE  @map("B-")
  AB_POSITIVE @map("AB+")
  AB_NEGATIVE @map("AB-")
  O_POSITIVE  @map("O+")
  O_NEGATIVE  @map("O-")

  @@map("blood_group")
}

enum UserStatus {
  ACTIVE               @map("active")
  PENDING_VERIFICATION @map("pending_verification")
  SUSPENDED            @map("suspended")
  DELETED              @map("deleted")

  @@map("user_status")
}

enum DonorVerification {
  UNVERIFIED @map("unverified")
  VERIFIED   @map("verified")
  REJECTED   @map("rejected")

  @@map("donor_verification")
}

enum RequestUrgency {
  ROUTINE   @map("routine")
  URGENT    @map("urgent")
  EMERGENCY @map("emergency")

  @@map("request_urgency")
}

enum RequestStatus {
  DRAFT          @map("draft")
  PENDING_REVIEW @map("pending_review")
  PUBLISHED      @map("published")
  MATCHED        @map("matched")
  IN_PROGRESS    @map("in_progress")
  FULFILLED      @map("fulfilled")
  CANCELLED      @map("cancelled")
  EXPIRED        @map("expired")
  UNFULFILLED    @map("unfulfilled")

  @@map("request_status")
}

enum ResponseStatus {
  ACCEPTED  @map("accepted")
  DECLINED  @map("declined")
  WITHDRAWN @map("withdrawn")

  @@map("response_status")
}

enum NotificationType {
  NEW_REQUEST    @map("new_request")
  STATUS_UPDATE  @map("status_update")
  DONOR_RESPONSE @map("donor_response")
  ANNOUNCEMENT   @map("announcement")

  @@map("notification_type")
}

enum AuthTokenPurpose {
  OTP            @map("otp")
  PASSWORD_RESET @map("password_reset")
  SESSION        @map("session")
  REFRESH        @map("refresh")

  @@map("auth_token_purpose")
}

model User {
  id                String       @id @default(uuid()) @db.Uuid
  fullName          String       @map("full_name") @db.VarChar(120)
  phone             String       @unique @db.VarChar(20)
  email             String?      @unique @db.VarChar(160)
  passwordHash      String       @map("password_hash") @db.VarChar(255)
  role              Role         @default(RECIPIENT)
  bloodGroup        BloodGroup?  @map("blood_group")
  locationId        String?      @map("location_id") @db.Uuid
  status            UserStatus   @default(PENDING_VERIFICATION)
  phoneVerified     Boolean      @default(false) @map("phone_verified")
  preferredLanguage String       @default("bn") @map("preferred_language") @db.VarChar(5)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  location        Location?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  donorProfile    DonorProfile?
  bloodRequests   BloodRequest[]    @relation("RecipientRequests")
  reviewedRequests BloodRequest[]   @relation("ReviewedRequests")
  requestResponses RequestResponse[] @relation("DonorResponses")
  notifications   Notification[]
  auditLogs       AuditLog[]        @relation("ActorAuditLogs")
  announcements   Announcement[]    @relation("AnnouncementAuthor")
  authTokens      AuthToken[]

  @@index([bloodGroup, locationId])
  @@map("users")
}

model DonorProfile {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String              @unique @map("user_id") @db.Uuid
  bloodGroup       BloodGroup          @map("blood_group")
  isAvailable      Boolean             @default(true) @map("is_available")
  verification     DonorVerification   @default(UNVERIFIED)
  lastDonationDate DateTime?           @map("last_donation_date") @db.Date
  nextEligibleDate DateTime?           @map("next_eligible_date") @db.Date
  totalDonations   Int                 @default(0) @map("total_donations")
  notes            String?
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@index([bloodGroup, isAvailable, verification])
  @@map("donor_profiles")
}

model Location {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  type      String   @db.VarChar(30)
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent        Location?      @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Location[]     @relation("LocationHierarchy")
  users         User[]
  bloodRequests BloodRequest[]

  @@index([parentId])
  @@map("locations")
}

model BloodRequest {
  id              String         @id @default(uuid()) @db.Uuid
  recipientId     String         @map("recipient_id") @db.Uuid
  patientName     String         @map("patient_name") @db.VarChar(120)
  patientAge      Int?           @map("patient_age")
  bloodGroup      BloodGroup     @map("blood_group")
  unitsNeeded     Int            @default(1) @map("units_needed")
  unitsFulfilled  Int            @default(0) @map("units_fulfilled")
  hospitalName    String         @map("hospital_name") @db.VarChar(160)
  locationId      String         @map("location_id") @db.Uuid
  urgency         RequestUrgency
  neededBy        DateTime       @map("needed_by")
  status          RequestStatus  @default(PENDING_REVIEW)
  notes           String?
  reviewedById    String?        @map("reviewed_by") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  recipient User              @relation("RecipientRequests", fields: [recipientId], references: [id], onDelete: Cascade)
  reviewedBy User?            @relation("ReviewedRequests", fields: [reviewedById], references: [id], onDelete: SetNull)
  location  Location          @relation(fields: [locationId], references: [id], onDelete: Restrict)
  responses RequestResponse[]
  donations Donation[]

  @@index([status, bloodGroup, locationId])
  @@index([neededBy])
  @@map("blood_requests")
}

model RequestResponse {
  id                           String         @id @default(uuid()) @db.Uuid
  requestId                    String         @map("request_id") @db.Uuid
  donorId                      String         @map("donor_id") @db.Uuid
  status                       ResponseStatus
  respondedAt                  DateTime       @default(now()) @map("responded_at")
  donorConfirmedCompletion     Boolean        @default(false) @map("donor_confirmed_completion")
  recipientConfirmedCompletion Boolean        @default(false) @map("recipient_confirmed_completion")
  createdAt                    DateTime       @default(now()) @map("created_at")
  updatedAt                    DateTime       @updatedAt @map("updated_at")

  request BloodRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  donor   User         @relation("DonorResponses", fields: [donorId], references: [id], onDelete: Cascade)

  @@unique([requestId, donorId])
  @@index([requestId])
  @@index([donorId])
  @@map("request_responses")
}

model Donation {
  id                 String   @id @default(uuid()) @db.Uuid
  donorProfileId     String   @map("donor_profile_id") @db.Uuid
  requestId          String?  @map("request_id") @db.Uuid
  donationDate       DateTime @map("donation_date") @db.Date
  units              Int      @default(1)
  recipientConfirmed Boolean  @default(true) @map("recipient_confirmed")
  createdAt          DateTime @default(now()) @map("created_at")

  donorProfile DonorProfile  @relation(fields: [donorProfileId], references: [id], onDelete: Cascade)
  request      BloodRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([donorProfileId])
  @@index([requestId])
  @@unique([donorProfileId, requestId])
  @@map("donations")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  type        NotificationType
  title       String           @db.VarChar(160)
  body        String
  referenceId String?          @map("reference_id") @db.Uuid
  isRead      Boolean          @default(false) @map("is_read")
  channel     String           @default("in_app") @db.VarChar(20)
  createdAt   DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Announcement {
  id          String   @id @default(uuid()) @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  title       String   @db.VarChar(160)
  body        String
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author User @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([isPublished])
  @@map("announcements")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  action     String   @db.VarChar(80)
  entityType String   @map("entity_type") @db.VarChar(40)
  entityId   String   @map("entity_id") @db.Uuid
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model AuthToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String?          @map("user_id") @db.Uuid
  phone     String?          @db.VarChar(20)
  tokenHash String           @unique @map("token_hash") @db.VarChar(255)
  purpose   AuthTokenPurpose
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([phone, purpose])
  @@map("auth_tokens")
}

model Setting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(80)
  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
