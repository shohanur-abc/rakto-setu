# NeonDB pooled connection (used by the app / PrismaClient)
DATABASE_URL="postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<database>?sslmode=require"
# NeonDB direct connection (used for `prisma migrate`)
DIRECT_URL="postgresql://<user>:<password>@<project>.<region>.aws.neon.tech/<database>?sslmode=require"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT="3000"

SEED_ADMIN_FULL_NAME="RaktoSetu Admin"
SEED_ADMIN_PHONE="+8801700000000"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
