# Base URL of the RaktoSetu API (including scheme, host, port — NO trailing slash).
#
# Leave EMPTY (recommended for local dev) to use the Vite dev-server proxy:
# the app calls same-origin `/api/v1/...` and Vite forwards it to PROXY_TARGET.
# Set it explicitly to hit a remote/deployed API directly, e.g.
#   VITE_API_URL=https://api.example.com
VITE_API_URL=

# When VITE_API_URL is empty, the dev server proxies `/api` to this target.
PROXY_TARGET=http://localhost:3000
